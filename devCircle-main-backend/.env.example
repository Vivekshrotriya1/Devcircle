PORT=7777
NODE_ENV=development
DB_CONNECTION_SECRET=mongodb+srv://username:password@cluster.example.net/devcircle
JWT_SECRET=replace-with-a-long-random-secret

# Gmail app password option
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Generic SMTP option. Use this instead of EMAIL_USER/EMAIL_PASS for providers
# like SendGrid, Mailgun, Brevo, Zoho, or Amazon SES.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=smtp-username
# SMTP_PASS=smtp-password
# EMAIL_FROM=no-reply@yourdomain.com

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
